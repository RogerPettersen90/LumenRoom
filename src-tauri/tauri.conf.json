{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumenRoom",
  "version": "0.9.0-beta.2",
  "identifier": "org.lumenroom.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LumenRoom (beta)",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' lumen: asset: data: blob: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Photography",
    "shortDescription": "Lightweight non-destructive RAW editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
